# Travel Companion Environment Configuration Template
# Copy this file to .env and fill in the actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Local PostgreSQL (for development)
DATABASE_URL=postgresql://travel_user:travel_password@localhost:5432/travel_companion

# Supabase Configuration (for production)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# =============================================================================
# CACHING & SESSION STORAGE
# =============================================================================

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# Amadeus Travel API (flights, hotels, etc.)
# Sign up at: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Booking.com API (accommodation)
# Sign up at: https://developers.booking.com/
BOOKING_API_KEY=your-booking-api-key
BOOKING_API_SECRET=your-booking-api-secret

# TripAdvisor API (attractions, reviews)
# Sign up at: https://developer-tripadvisor.com/
TRIPADVISOR_API_KEY=your-tripadvisor-api-key

# =============================================================================
# AI & LLM CONFIGURATION
# =============================================================================

# OpenAI API (for LangGraph agents)
# Sign up at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.1

# =============================================================================
# FRONTEND CONFIGURATION (Next.js)
# =============================================================================

# Next.js Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# EMAIL & NOTIFICATIONS
# =============================================================================

# Email Configuration (for notifications, password reset, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@travelcompanion.app

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Sentry (Error Tracking) - Optional
SENTRY_DSN=your-sentry-dsn

# LogLevel (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# JWT Configuration
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Hot Reload (for development)
HOT_RELOAD=true

# Database Migration
AUTO_MIGRATE=false

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Docker Compose Services
COMPOSE_PROJECT_NAME=travel-companion

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit the actual .env file to version control
# 2. Keep this .env.example file updated when adding new environment variables
# 3. Use strong, unique passwords and API keys
# 4. For production, use environment-specific values
# 5. Consider using a secret management service for production deployments